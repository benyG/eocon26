# Copy this file to .env and fill in your values
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/eocon"

# Admin password (used to log in at /admin/login)
ADMIN_PASSWORD="change-me-strong-password"

# Secret used to sign the admin session cookie — any random string
ADMIN_SECRET="change-me-random-secret-32-chars"

# Your domain name — required for Let's Encrypt (must point to this server)
DOMAIN="eyesopensecurity.com"

# Public site URL — used to build Stripe success/cancel redirect URLs and email links
NEXT_PUBLIC_URL="https://eyesopensecurity.com"

# Set to "true" once HTTPS is active (Caddy handles it automatically)
COOKIE_SECURE="true"

# Google Cloud Storage — image uploads
GOOGLE_APPLICATION_CREDENTIALS="gcs-service-account.json"
GCS_BUCKET_NAME="eocon-assets"

# Resend — transactional emails
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="EOCON 2026 <noreply@eyesopensecurity.com>"

# NetTicket — Mobile Money payments (https://netticket.net/developers)
# Used for Cameroon visitors (XAF / Mobile Money).
NETTICKET_API_KEY="..."                 # x-api-key from your NetTicket account settings
NETTICKET_EVENT_REFERENCE="..."         # event reference (used to list tickets)
NETTICKET_BASE_URL="https://netticket.net/api"

# Stripe — card payments (https://dashboard.stripe.com/apikeys)
# Used for non-Cameroon visitors (USD / card). We use Stripe Checkout (hosted),
# so NO card data ever reaches our app or database — only the session id is kept.
#
# Tenant note (Option A): the Stripe account owner is examboot.net, while the
# payment page is hosted here on eyesopensecurity.com. Both keys below come from
# examboot.net's Stripe dashboard. Prefer a Restricted key limited to
# "Checkout Sessions: write" + "Payment Intents: read". See docs/stripe-webhook-setup.md.
STRIPE_SECRET_KEY="sk_live_or_test_..."
# Webhook signing secret from examboot.net's Stripe dashboard (Developers → Webhooks).
# Configure an endpoint at  https://eyesopensecurity.com/api/payment/stripe/webhook
# subscribed to the event `checkout.session.completed`.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Currency is strictly geo-driven: Cameroon → XAF (Mobile Money), others → USD (Stripe).
# Set to "true" ONLY for QA to expose a manual XAF/USD selector in the registration modal.
PAYMENT_ALLOW_CURRENCY_SELECTOR="false"

# AI & Enrichment APIs
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"   # or gpt-4o, gpt-4-turbo, etc.
LINKEDIN_AUTHOR_URN="urn:li:person:YOUR_ID"  # or urn:li:organization:YOUR_ORG_ID
# OAuth 2.0 — required for automatic token refresh (recommended)
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."
LINKEDIN_REFRESH_TOKEN="..."    # Initial refresh token (365-day validity); auto-renewed in DB
# Fallback without auto-refresh (expires in 60 days, manual renewal):
# LINKEDIN_ACCESS_TOKEN="..."

# X (Twitter) — OAuth 1.0a User Context
# Create an app at https://developer.x.com → Keys and tokens → Read+Write permission
X_API_KEY="..."               # Consumer Key (App Key)
X_API_SECRET="..."            # Consumer Secret (App Secret)
X_ACCESS_TOKEN="..."          # Access Token
X_ACCESS_TOKEN_SECRET="..."   # Access Token Secret

# Restream — OAuth 2.0 (https://developers.restream.io)
# Create an app at https://restream.io/settings/apps, add the redirect URI below.
# Scopes to enable: channel.read, stream.read, channel.update (captions/tickers)
RESTREAM_CLIENT_ID="..."
RESTREAM_CLIENT_SECRET="..."
# Redirect URI registered in your Restream app settings
RESTREAM_REDIRECT_URI="https://ton-domaine.com/api/admin/live/restream/callback"

CRON_SECRET="change-me-cron-secret"
# Cron endpoints (call regularly via cURL or Vercel Cron):
#   GET /api/cron/publish-scheduled?secret=$CRON_SECRET    (social posts)
#   GET /api/cron/pilotage-reminders?secret=$CRON_SECRET   (steering deadline/meeting reminders, run hourly)
APOLLO_API_KEY="..."
GOOGLE_PLACES_API_KEY="..."

# Dedicated secret for signing payment ownership tokens (falls back to ADMIN_SECRET)
PAYMENT_SECRET="change-me-payment-secret"

# Optional shared rate-limit backend (Upstash Redis REST). When unset, the
# limiter falls back to an in-memory store (per-instance).
UPSTASH_REDIS_REST_URL="..."
UPSTASH_REDIS_REST_TOKEN="..."
