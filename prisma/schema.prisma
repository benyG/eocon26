generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model CFPSubmission {
  id             Int       @id @default(autoincrement())
  name           String
  email          String
  org            String?
  country        String?
  talkTitle      String
  format         String?
  abstract       String    @db.Text
  bio            String?   @db.Text
  linkedin         String?
  twitter          String?
  whatsapp         String?
  certifications   String?   @db.Text
  langPresentation String?   @default("fr")
  // Pipeline: submitted | reviewing | accepted | rejected | onboarding | confirmed | scheduled
  status         String    @default("pending")
  pipelineStage  String    @default("submitted")
  deferred       Boolean   @default(false) // submitted outside the CFP window — kept for a later edition
  notes          String?   @db.Text
  decisionSentAt DateTime?
  aiScore        Float?
  aiAnalysis     String?   @db.Text
  createdAt      DateTime  @default(now())
  // Link to Speaker created on acceptance
  speakerId      Int?      @unique
  speaker        Speaker?  @relation(fields: [speakerId], references: [id])

  @@map("cfp_submissions")
}

model VolunteerApplication {
  id              Int       @id @default(autoincrement())
  name            String
  email           String
  phone           String?
  city            String?
  role            String?
  experience      String?   @db.Text
  motivation      String    @db.Text
  linkedin        String?
  twitter         String?
  whatsapp        String?
  hoursPerWeek    String?
  langExpression  String?   @default("fr")
  status          String    @default("pending")
  volunteerStage  String    @default("submitted")
  assignedRole    String?
  shiftStart      DateTime?
  shiftEnd        DateTime?
  createdAt       DateTime  @default(now())

  @@map("volunteer_applications")
}

model Registration {
  id                 Int       @id @default(autoincrement())
  fname              String
  lname              String
  email              String
  org                String?
  country            String?
  ticketType         String
  ticketRef          String?   @unique
  langExpression     String?   @default("fr")
  status             String    @default("pending")
  qrCode             String?
  checkedInAt        DateTime?
  checkedInBy        String?
  linkedin           String?
  whatsapp           String?
  ctfCompetitorName  String?
  ctfTeamName        String?
  ctfPassword        String?
  ctfAccountCreated  Boolean   @default(false)
  // Payment tracking (NetTicket Mobile Money / future Stripe)
  paymentProvider    String?   // netticket_mtn | netticket_orange | stripe | free
  paymentRef         String?   // transaction id returned by the payment provider
  paidAt             DateTime?
  // Online access (magic link)
  onlineToken        String?   @unique
  onlineCheckedInAt  DateTime?
  onlineAccessSentAt DateTime?
  onlineSessions     OnlineSession[]
  createdAt          DateTime  @default(now())

  @@map("registrations")
}

model OnlineSession {
  id             Int          @id @default(autoincrement())
  registrationId Int
  registration   Registration @relation(fields: [registrationId], references: [id])
  sessionToken   String       @unique
  expiresAt      DateTime
  lastSeenAt     DateTime?
  ipAddress      String?
  userAgent      String?      @db.Text
  createdAt      DateTime     @default(now())

  @@map("online_sessions")
}

model Speaker {
  id              Int      @id @default(autoincrement())
  name            String
  title           String
  company         String?
  country         String?
  bio             String   @db.Text
  photoUrl        String?
  visualUrl       String?  // Infographist-produced visual for social posts (distinct from profile photo)
  linkedin        String?
  twitter         String?
  talkTitle       String?
  talkAbstract    String?  @db.Text
  talkFormat      String?
  isKeynote       Boolean            @default(false)
  edition         String             @default("2026")
  isVisible       Boolean            @default(true)
  sortOrder       Int                @default(0)
  // Onboarding tracking
  onboardingStatus String?  @default("pending") // pending | sent | completed
  createdAt       DateTime           @default(now())
  onboarding      SpeakerOnboarding?
  cfpSubmission   CFPSubmission?

  @@map("speakers")
}

model Sponsor {
  id        Int      @id @default(autoincrement())
  name      String
  logoUrl   String?
  website   String?
  email     String?
  phone     String?
  tier      String   // PLATINUM | GOLD | SILVER | BRONZE
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("sponsors")
}

model ConferenceSession {
  id           Int       @id @default(autoincrement())
  date         String?   // YYYY-MM-DD — the actual event day
  time         String    // display time e.g. "09:00"
  endTime      String?   // e.g. "10:00"
  title        String
  type         String    // keynote | talk | workshop | panel | break | logistics
  speakerName  String?
  speakerId    Int?      // FK to Speaker (optional)
  workshopId   Int?      // FK to Workshop (optional)
  workshop     Workshop? @relation(fields: [workshopId], references: [id], onDelete: SetNull)
  room         String?
  description  String?   @db.Text
  mode         String?   // online | onsite | hybrid — set when the session is programmed
  zoomLink     String?   // link shared with the speaker for online sessions
  slidesDeadline String? // deadline to send slides (free text, e.g. "21 octobre 2026")
  sortOrder    Int       @default(0)
  isVisible    Boolean   @default(true)
  displayFrom  DateTime? // show on frontend only from this date
  displayUntil DateTime? // hide after this date
  createdAt    DateTime  @default(now())

  @@map("sessions")
}

model Workshop {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  level       String   // beginner | intermediate | advanced
  duration    String   @default("3h")
  maxSeats    Int?
  instructor  String?
  isVisible   Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  sessions    ConferenceSession[]

  @@map("workshops")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  email     String?
  bio       String?  @db.Text
  photoUrl  String?
  linkedin  String?
  twitter   String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("team_members")
}

// ── Pilotage Global (steering) ──────────────────────────────────────────────
model SteeringTask {
  id            Int       @id @default(autoincrement())
  title         String    @db.Text
  description   String?   @db.Text
  phase         Int       @default(1) // 1..6
  pole          String    // role name
  subTeam       String?   // Contenu | Sponsors | Tech | Logistique | Volontaires | Général
  status        String    @default("todo") // backlog|todo|in_progress|blocked|review|done
  priority      String    @default("medium") // low|medium|high|critical
  assigneeName  String?
  assigneeEmail String?
  dueDate       DateTime?
  isMilestone   Boolean   @default(false)
  reminderStage String?   // CSV of reminders sent: J-3,J-1,J0,overdue
  notes         String?   @db.Text
  sortOrder     Int       @default(0)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([phase])
  @@index([status])
  @@map("steering_tasks")
}

model SteeringMeeting {
  id             Int      @id @default(autoincrement())
  title          String
  type           String   @default("collective") // collective|subteam
  subTeam        String?
  scheduledAt    DateTime
  location       String?
  agenda         String?  @db.Text
  attendees      String?  @db.Text // JSON: [{name, email}] — les personnes convoquées
  convenerEmail  String?  // email du convocateur (TeamMember)
  convenerName   String?  // nom affiché du convocateur
  reminderStage  String?  // CSV des rappels envoyés: "J-1,J0"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("steering_meetings")
}

model PastSpeaker {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  company   String?
  country   String?
  edition   String?  // e.g. "2024", "2023"
  photoUrl  String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("past_speakers")
}

model NewsletterSubscriber {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  firstName  String?
  lastName   String?
  phone      String?
  profession String?
  company    String?
  twitter    String?
  linkedin   String?
  source     String?  @default("form")
  createdAt  DateTime @default(now())

  @@map("newsletter_subscribers")
}

model AdminProfile {
  id          Int       @id @default(autoincrement())
  slug        String    @unique // e.g. "super_admin"
  name        String
  description String    @default("")
  color       String    @default("#888888")
  permissions String    @db.Text // JSON AdminPermissions
  isSystem    Boolean   @default(false) // system profiles can't be deleted
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       AdminUser[]

  @@map("admin_profiles")
}

model AdminUser {
  id             Int            @id @default(autoincrement())
  name           String
  email          String         @unique
  passwordHash   String
  permissions    String         @db.Text // JSON: { cfp: "write", speakers: "read", ... }
  isActive       Boolean        @default(true)
  profileId      Int?
  profile        AdminProfile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  sessions       AdminSession[]
  mfaSecret      String?        @db.Text  // encrypted TOTP secret
  mfaEnabled     Boolean        @default(false)
  mfaEnrolledAt  DateTime?
  failedLoginCount Int          @default(0)
  lockedUntil    DateTime?

  @@map("admin_users")
}

model AdminSession {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_sessions")
}

model SpeakerOnboarding {
  id                 Int      @id @default(autoincrement())
  speakerId          Int      @unique
  selectionMailSent  Boolean  @default(false)
  modalitiesMailSent Boolean  @default(false)
  timingMailSent     Boolean  @default(false)
  bioReceived        Boolean  @default(false)
  photoReceived      Boolean  @default(false)
  slidesReceived     Boolean  @default(false)
  transportArranged  Boolean  @default(false)
  accommodationDone  Boolean  @default(false)
  agreementSigned    Boolean  @default(false)
  notes              String?  @db.Text
  updatedAt          DateTime @updatedAt
  speaker            Speaker  @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@map("speaker_onboarding")
}

model TicketCapacity {
  id           Int    @id @default(autoincrement())
  ticketType   String @unique
  maxCapacity  Int    @default(100)
  alertPercent Int    @default(80)

  @@map("ticket_capacities")
}

model TicketType {
  id              Int      @id @default(autoincrement())
  slug            String   @unique // "standard", "student", "vip"
  nameFr          String
  nameEn          String
  priceFr         Int      @default(0) // price in XAF
  priceEn         Int      @default(0) // price in USD
  perksFr         String   @db.Text  // JSON string[]
  perksEn         String   @db.Text  // JSON string[]
  earlyBirdPriceFr Int?
  earlyBirdPriceEn Int?
  earlyBirdUntil  DateTime?
  color           String   @default("#00ff9d")
  isFeatured      Boolean  @default(false)
  isVisible       Boolean  @default(true)
  includesSessions  Boolean  @default(true)   // access to live keynotes/talks/panels
  includesWorkshops Boolean  @default(false)  // access to workshop rooms (JaaS)
  includesCTF       Boolean  @default(false)  // access to CTF platform
  maxCapacity     Int      @default(200)
  sortOrder       Int      @default(0)
  // External payment provider mappings
  netticketTicketId String? // NetTicket ticket id (used by /payment/mobile)
  stripeProductId   String? // Stripe product/price id (future card integration)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ticket_types")
}

model CTFChallenge {
  id          Int      @id @default(autoincrement())
  title       String
  category    String   // Web | Crypto | Forensics | Reverse | Pwn | OSINT | Misc
  difficulty  String   @default("medium") // easy | medium | hard
  points      Int      @default(0)
  author      String?
  status        String   @default("idea") // idea | in_progress | testing | validated | published
  ctfdId        Int?     // CTFd challenge ID after publish
  notes         String?  @db.Text
  assigneeName  String?  // Team member responsible for this challenge
  assigneeEmail String?  // Notified when (re)assigned
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("ctf_challenges")
}

model EmailTemplate {
  id          Int       @id @default(autoincrement())
  slug        String?   @unique
  name        String
  subject     String                       // FR subject (primary)
  htmlBody    String    @db.LongText        // FR body (primary)
  subjectEn   String?                       // EN subject
  htmlBodyEn  String?   @db.LongText        // EN body
  variables   String?   @db.Text
  segment     String    @default("all") // all | registered | cfp_accepted | volunteers | newsletter
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  @@map("email_templates")
}

model EmailLog {
  id          Int       @id @default(autoincrement())
  templateId  Int?
  campaignId  Int?
  recipient   String
  subject     String
  status      String    @default("sent") // sent | failed
  resendId    String?   // Resend message id, used to correlate webhook events
  deliveredAt DateTime? // set by Resend webhook (email.delivered)
  openedAt    DateTime? // set by Resend webhook (email.opened)
  clickedAt   DateTime? // set by Resend webhook (email.clicked)
  bouncedAt   DateTime? // set by Resend webhook (email.bounced)
  sentAt      DateTime  @default(now())

  @@index([campaignId])
  @@index([resendId])
  @@map("email_logs")
}

model Campaign {
  id             Int       @id @default(autoincrement())
  name           String
  templateId     Int?                       // source EmailTemplate (bilingual content)
  subject        String                     // FR subject snapshot (what was/ will be sent)
  htmlBody       String    @db.LongText      // FR body snapshot
  subjectEn      String?                     // EN subject snapshot
  htmlBodyEn     String?   @db.LongText      // EN body snapshot
  segment        String    @db.Text   // JSON granular audience filter
  status         String    @default("draft") // draft | sending | sent | failed
  recipientCount Int       @default(0)
  sentCount      Int       @default(0)
  failedCount    Int       @default(0)
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([templateId])
  @@map("campaigns")
}

model SponsorProspect {
  id        Int      @id @default(autoincrement())
  org       String
  contact   String?
  email     String?
  phone     String?
  website   String?
  package   String?  // tier/package name
  status    String   @default("contacted") // contacted | meeting | negative | positive | concluded | abandoned | paused
  notes     String?  @db.Text
  emailJson String?  @db.Text // cached AI follow-up email (JSON)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sponsor_prospects")
}

model BudgetItem {
  id        Int      @id @default(autoincrement())
  category  String   @default("costs") // revenue | costs
  label     String
  planned   Float    @default(0)
  actual    Float    @default(0)
  status      String   @default("pending") // pending | paid | cancelled
  responsable String?
  createdAt   DateTime @default(now())

  @@map("budget_items")
}

model LogisticsTask {
  id        Int      @id @default(autoincrement())
  category  String
  title     String
  assignee  String?
  deadline  DateTime?
  done      Boolean  @default(false)
  status    String   @default("todo")
  priority  String   @default("medium")
  phase     String   @default("J-30")
  notes     String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("logistics_tasks")
}

model SocialPost {
  id             Int       @id @default(autoincrement())
  brief          String    @db.Text
  platform       String    // linkedin | twitter | instagram
  lang           String    // fr | en
  content        String    @db.Text
  imageUrl       String?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  linkedinPostId String?
  status         String    @default("draft") // draft | scheduled | published | failed
  errorMessage   String?   @db.Text
  createdAt      DateTime  @default(now())
  contentType    String?   // speaker_announcement | speaker_reminder | session | inscription | cfp | ctf | custom
  speakerId      Int?      // optional link to speaker (for auto-posts)

  @@map("social_posts")
}

model ProspectLead {
  id                 Int      @id @default(autoincrement())
  source             String   @default("manual") // apollo | google_places | manual
  org                String
  sector             String?
  city               String?
  website            String?
  phone              String?
  contactName        String?
  contactTitle       String?
  contactEmail       String?
  contactLinkedin    String?
  aiScore            Float?
  aiScoreReason      String?  @db.Text
  recommendedPackage String?
  addedToPipeline    Boolean  @default(false)
  pitchJson          String?  @db.Text // cached AI pitch strategy (JSON)
  emailJson          String?  @db.Text // cached AI prospecting email (JSON)
  createdAt          DateTime @default(now())

  @@map("prospect_leads")
}

model EventSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("event_settings")
}

model CyberWatchItem {
  id           Int       @id @default(autoincrement())
  sourceId     String    @db.VarChar(50)
  sourceName   String    @db.VarChar(100)
  title        String    @db.Text
  url          String    @db.Text
  summary      String    @db.LongText
  aiScore      Float     @default(0)
  aiReason     String?   @db.Text
  draftFr      String    @db.LongText
  draftEn      String    @db.LongText
  status       String    @default("pending") // pending | approved | rejected | scheduled
  platforms    String    @default("linkedin") // comma-separated: linkedin,twitter
  scheduledAt  DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([status])
  @@index([expiresAt])
  @@map("cyber_watch_items")
}

model SponsorPackage {
  id             Int      @id @default(autoincrement())
  tier           String   @unique // PLATINUM | GOLD | SILVER | BRONZE | PARTNER
  nameFr         String
  nameEn         String
  price          Int      // in FCFA
  maxSponsors    Int      @default(1)
  perks          String   @db.Text // JSON array of perk strings
  perksFr        String   @db.Text // JSON array
  perksEn        String   @db.Text // JSON array
  isVisible      Boolean  @default(true)
  sortOrder      Int      @default(0)
  highlightColor String?  // hex color for display
  createdAt      DateTime @default(now())

  @@map("sponsor_packages")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  actor      String   @default("admin") // email or "admin" for shared-token sessions
  ip         String?  @db.VarChar(45)
  action     String   @db.VarChar(50)  // CREATE | UPDATE | DELETE | LOGIN | VALIDATE | REJECT | ...
  resource   String   @db.VarChar(50)  // session | speaker | registration | volunteer | cfp | user | ...
  resourceId String?  @db.VarChar(50)
  details    Json?                      // arbitrary payload for context
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([resource])
  @@map("audit_logs")
}

model BadgeCredential {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(cuid())
  badgeType      String    // participant | speaker | volunteer | ctf_competitor | ctf_winner | organizer
  subtype        String?   // ticket level for participant (student/standard/vip), null for others
  recipientName  String
  recipientEmail String
  credentialJson String    @db.LongText
  issuedAt       DateTime  @default(now())
  revokedAt      DateTime?
  emailSentAt    DateTime?

  @@index([recipientEmail])
  @@index([badgeType])
  @@map("badge_credentials")
}

model SessionVideo {
  id            Int      @id @default(autoincrement())
  title         String
  titleEn       String?
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  youtubeUrl    String
  thumbnailUrl  String?
  speaker       String?
  edition       String   @default("2025")
  category      String?  // keynote | talk | workshop | panel
  isVisible     Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  @@map("session_videos")
}

model PaymentTransaction {
  id              Int      @id @default(autoincrement())
  registrationId  Int?     // linked registration (if any)
  email           String
  phone           String?  // Mobile Money number used by the payer
  provider        String   // netticket_mtn | netticket_orange | stripe
  amount          Int      @default(0)
  ticketType      String?
  state           String   @default("pending") // pending | success | failed
  reason          String?  // success | insufficient_funds | failed | unavailable
  providerRef     String?  // transaction id returned by the provider
  message         String?  @db.Text // final provider response message
  ticketEmailSent Boolean  @default(false) // whether the ticket email was delivered (Resend)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([registrationId])
  @@index([state])
  @@map("payment_transactions")
}

model Testimony {
  id        Int      @id @default(autoincrement())
  quoteEn   String   @db.Text
  quoteFr   String?  @db.Text
  author    String
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("testimonies")
}

model SessionQuestion {
  id           Int      @id @default(autoincrement())
  body         String   @db.Text
  displayName  String?
  sessionToken String?
  approved     Boolean  @default(false)
  answered     Boolean  @default(false)
  hidden       Boolean  @default(false)
  upvotes      Int      @default(0)
  adminNote    String?  @db.Text
  askedAt      DateTime @default(now())

  @@map("session_questions")
}
